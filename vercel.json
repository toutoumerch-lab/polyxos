{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://polyxos.onrender.com/api/$1"
    },
    {
      "source": "/brand/(.*)",
      "destination": "https://polyxos.onrender.com/brand/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
